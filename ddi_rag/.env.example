# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Use the External Database URL from Render (or local postgresql://...)
DATABASE_URL=postgresql://ddi_user:your_password@dpg-xxxx.oregon-postgres.render.com/ddi_rag

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-random-32-char-hex-string
JWT_ACCESS_TOKEN_MINS=1440

# ── HuggingFace (optional, kept for reference) ────────────────────────────────
HF_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# ── Groq API (primary LLM — free at console.groq.com) ────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.1-8b-instant

# ── Redis (optional — leave blank to use in-memory LRU cache) ─────────────────
REDIS_URL=

# ── App paths ─────────────────────────────────────────────────────────────────
DDI_PORT=5000
DDI_DATA_CSV=./data/clean_ddi_dataset.csv
DDI_CHROMA_DIR=./chroma_ddi_db
